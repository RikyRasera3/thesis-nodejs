{
  "compilerOptions": {
    "alwaysStrict": true,
    "allowJs": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "node20",
    "moduleResolution": "nodenext",
    "newLine": "LF",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "strict": true,
    "target": "es2024"
  },
  "exclude": [
    "database/",
    "dist/",
    "grafana/",
    "node_modules/"
  ],
  "include": [
    "src/"
  ],
  "types": [
    "@fastify/express"
  ]
}